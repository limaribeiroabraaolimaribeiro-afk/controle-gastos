<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BankListener" parent="android:Theme.Material.NoTitleBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.BankListener.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#07101f</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.BankListener</item>
    </style>
</resources>
